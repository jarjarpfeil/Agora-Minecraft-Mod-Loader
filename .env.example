# Environment variables for the Agora monorepo.
# Copy this file to .env and fill in real values. .env is gitignored.
# The compiler automatically loads .env at startup.

# CI-only Ed25519 private key (hex, 32 or 64 bytes) used to sign registry.db.
# NEVER commit this value. Configure it as a GitHub repository secret.
ED25519_PRIVATE_KEY=

# Standard GitHub token used by the nightly compiler and issue forms.
GITHUB_TOKEN=

# Optional token for the local Agora launcher MCP server (see AGENTS.md).
LAUNCHER_MCP_TOKEN=

# NOTE: AGORA_OAUTH_CLIENT_ID and AGORA_REGISTRY_PUBKEY are intentionally NOT
# in this file. Both are read by the Tauri Rust build at COMPILE time via
# option_env!(), so they must be set as real environment variables in the
# shell that runs `npm run tauri:dev` — not in .env (which is loaded at
# runtime by the Python compiler only). See README.md >
# "Environment variables for the Tauri build" for setup steps.
