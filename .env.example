# Environment variables for the Agora monorepo.
# Copy this file to .env and fill in real values. .env is gitignored.
# The compiler automatically loads .env at startup (only the Python compiler;
# the Tauri Rust build does NOT read .env -- it uses option_env!() at compile time).

# CI-only Ed25519 private key (hex, 32 or 64 bytes) used to sign registry.db.
# NEVER commit this value. Configure it as a GitHub repository secret.
ED25519_PRIVATE_KEY=

# Standard GitHub token used by the nightly compiler and issue forms.
GITHUB_TOKEN=

# Optional Discord webhook URL for curator alerts (velocity circuit breaker,
# coordinated-attack notifications). Optional -- when unset, all Discord
# notifications are silently skipped (curator alerts fall back to audit-trail
# + admin-alert GitHub issue only).
DISCORD_WEBHOOK_URL=

# Optional Bearer token for the local Agora launcher MCP server
# (127.0.0.1:39741). NOTE: this token is not yet enforced by the MCP server
# (deferred per MASTER_SPEC section 19.6) -- the localhost binding is the
# current sole security boundary. When the auth check lands, this is the
# value AI clients will need to present.
LAUNCHER_MCP_TOKEN=

# NOTE: AGORA_OAUTH_CLIENT_ID and AGORA_REGISTRY_PUBKEY are intentionally NOT
# in this file. Both are read by the Tauri Rust build at COMPILE time via
# option_env!(), so they must be set as real environment variables in the
# shell that runs `npm run tauri:dev` -- not in .env (which is loaded at
# runtime by the Python compiler only). See README.md >
# "Environment variables for the Tauri build" for setup steps.